        <w:t>3、甲方不能按照本合同规定支付劳动报酬或者提供劳动条件的；</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:pPr>
        <w:pStyle w:val="4"/>
        <w:spacing w:line="500" w:lineRule="exact"/>
