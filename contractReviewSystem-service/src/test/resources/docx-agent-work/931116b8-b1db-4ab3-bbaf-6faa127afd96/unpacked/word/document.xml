          <w:sz w:val="28"/>
          <w:szCs w:val="28"/>
        </w:rPr>
        <w:t xml:space="preserve">4、甲方违反国家有关规定，劳动安全卫生条件恶劣，严重危害乙方身体健康的； </w:t>
      </w:r>
    </w:p>
