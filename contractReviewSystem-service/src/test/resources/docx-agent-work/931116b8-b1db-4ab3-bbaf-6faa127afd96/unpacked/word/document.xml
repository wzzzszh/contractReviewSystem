        <w:t xml:space="preserve">2、甲方以侵害乙方合法人身权利手段强迫劳动的； </w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:pPr>
        <w:pStyle w:val="4"/>
        <w:spacing w:line="500" w:lineRule="exact"/>
